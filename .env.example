# Copy to .env and fill in. Never commit .env.

# --- LLM provider ---
# Examples:
#   anthropic/claude-sonnet-4-5
#   openai/gpt-4o-mini
#   gemini/gemini-1.5-flash
#   openrouter/anthropic/claude-3.5-sonnet
#   ollama/llama3.1               (local Ollama)
#   ollama_chat/qwen2.5-coder     (local Ollama, chat-formatted)
S0_MODEL=anthropic/claude-sonnet-4-5

# --- Hosted-provider keys (set the one matching S0_MODEL) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# --- OpenRouter (gateway to ~100 hosted models) ---
# https://openrouter.ai — usage: S0_MODEL=openrouter/<vendor>/<model>
# OPENROUTER_API_BASE only needed if you proxy through a custom URL.
OPENROUTER_API_KEY=
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# --- Ollama (local OR cloud-hosted, OpenAI-compatible servers) ---
# Local default: leave OLLAMA_API_BASE empty (litellm uses http://localhost:11434).
# Cloud / remote: point OLLAMA_API_BASE at your endpoint; set OLLAMA_API_KEY if
# the proxy requires bearer auth.
# Example local:    S0_MODEL=ollama/llama3.1
# Example remote:   S0_MODEL=ollama_chat/qwen2.5-coder + OLLAMA_API_BASE=https://ollama.mycorp.com
# OLLAMA_API_BASE=
# OLLAMA_API_KEY=

# --- Any OpenAI-compatible self-hosted endpoint (vLLM, llama.cpp, LM Studio, …) ---
# Use S0_MODEL=openai/<your-model-name> with the local URL below.
# OPENAI_API_BASE=http://localhost:8000/v1

# --- Azure OpenAI ---
# S0_MODEL=azure/<deployment-name>
# AZURE_API_KEY=
# AZURE_API_BASE=https://<resource>.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview

# --- Harness defaults ---
# Default seed harness used by `s0 scan` when --harness is not given.
S0_DEFAULT_HARNESS=baseline_v0_agentic

# Cap on tool-loop turns per scan 
S0_MAX_TURNS=10

# Cap on input tokens per scan. Loop stops when exceeded.
S0_TOKEN_BUDGET=200000

# Per-observation byte cap
S0_OUTPUT_CAP_BYTES=30000

# --- Run store ---
# Where to write runs/<ts>__<harness>__<id>/ artifacts.
S0_RUNS_DIR=./runs

# --- Severity floor for `--fail-on` ---
# One of: info, low, medium, high, critical.
S0_FAIL_ON=high
