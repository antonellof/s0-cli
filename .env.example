# Copy to .env and fill in. Never commit .env.

# --- LLM provider ---
# Default model name passed to litellm. Any litellm-compatible string works.
S0_MODEL=anthropic/claude-sonnet-4-5

# Provider keys. Only the one matching S0_MODEL is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Harness defaults ---
# Default seed harness used by `s0 scan` when --harness is not given.
S0_DEFAULT_HARNESS=baseline_v0_agentic

# Cap on tool-loop turns per scan (KIRA-style budget).
S0_MAX_TURNS=30

# Cap on input tokens per scan. Loop stops when exceeded.
S0_TOKEN_BUDGET=200000

# Per-observation byte cap (KIRA: 30KB).
S0_OUTPUT_CAP_BYTES=30000

# --- Run store ---
# Where to write runs/<ts>__<harness>__<id>/ artifacts.
S0_RUNS_DIR=./runs

# --- Severity floor for `--fail-on` ---
# One of: info, low, medium, high, critical.
S0_FAIL_ON=high
